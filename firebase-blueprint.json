{
  "entities": {
    "SiteData": {
      "title": "Site Configuration",
      "description": "Main configuration and content for the landing page",
      "type": "object",
      "properties": {
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "title": { "type": "string" },
        "logoIcon": { "type": "string" },
        "heroSlogan": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroButtonText": { "type": "string" },
        "heroImages": { "type": "array", "items": { "type": "string" } },
        "highlightsTitle": { "type": "string" },
        "highlightsSubtitle": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "object" } },
        "galleryTitle": { "type": "string" },
        "gallerySubtitle": { "type": "string" },
        "galleryDescription": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "locationTitle": { "type": "string" },
        "locationSubtitle": { "type": "string" },
        "locationMaps": { "type": "array", "items": { "type": "string" } },
        "locationButtonText": { "type": "string" },
        "locationFeatures": { "type": "array", "items": { "type": "object" } },
        "floorPlansTitle": { "type": "string" },
        "floorPlansSubtitle": { "type": "string" },
        "floorPlans": { "type": "array", "items": { "type": "object" } },
        "noticesTitle": { "type": "string" },
        "noticesSubtitle": { "type": "string" },
        "notices": { "type": "array", "items": { "type": "object" } },
        "inquiryTitle": { "type": "string" },
        "inquirySubtitle": { "type": "string" },
        "inquiryDescription": { "type": "string" },
        "inquiryButtonText": { "type": "string" },
        "footerCopyright": { "type": "string" },
        "footerInfo": { "type": "object" },
        "quickMenu": { "type": "object" },
        "themeColor": { "type": "string" },
        "fontFamily": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/site/data": {
      "schema": "SiteData",
      "description": "The single source of truth for the site's content"
    }
  }
}
